rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read/write their own conversation (conversationId = user.uid)
    match /conversations/{conversationId} {
      allow read, write: if request.auth != null && request.auth.uid == conversationId;
      // Users can only read/write messages in their own conversation
      match /messages/{messageId} {
        allow read, write: if request.auth != null && request.auth.uid == conversationId;
      }
    }
    // Users read their own meals; Cloud Functions create them; users may update/delete their own.
    // Partial updateDoc() merges fields — comparing request.resource.data.userId to resource.data.userId
    // can fail in rules; instead allow updates that only touch editable fields.
    match /meals/{mealId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if false;
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['foodItems', 'estimatedCalories', 'macros']);
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    // Users can read/write their own profile (onboarding, settings)
    match /userProfiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
