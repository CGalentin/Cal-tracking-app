rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /images/{conversationId}/{filename} {
      allow read, write: if request.auth != null && request.auth.uid == conversationId;
    }
    match /audio/{conversationId}/{filename} {
      allow read, write: if request.auth != null && request.auth.uid == conversationId;
    }
  }
}
